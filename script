SELECT 
    lower(regexp_extract(document_name, '\\.([^.]+)$', 1)) AS extension,
    COUNT(*) AS total_documents,
    AVG(TRY_CAST(summary_score AS DOUBLE)) AS avg_score,
    MIN(TRY_CAST(summary_score AS DOUBLE)) AS min_score,
    MAX(TRY_CAST(summary_score AS DOUBLE)) AS max_score
FROM document_metadata_score_report
WHERE document_name IS NOT NULL
AND TRY_CAST(summary_score AS DOUBLE) IS NOT NULL
GROUP BY lower(regexp_extract(document_name, '\\.([^.]+)$', 1))
ORDER BY avg_score DESC;


SELECT 
    lower(regexp_extract(document_name, '\\.([^.]+)$', 1)) AS extension,
    COUNT(*) AS total_documents,
    AVG(TRY_CAST(summary_score AS DOUBLE)) AS avg_score,
    MIN(TRY_CAST(summary_score AS DOUBLE)) AS min_score,
    MAX(TRY_CAST(summary_score AS DOUBLE)) AS max_score
FROM document_metadata_score_report
WHERE document_name IS NOT NULL
  AND TRY_CAST(summary_score AS DOUBLE) IS NOT NULL
GROUP BY lower(regexp_extract(document_name, '\\.([^.]+)$', 1))
ORDER BY avg_score DESC;


SELECT 
    lower(regexp_extract(document_name, '\\.([^.]+)$', 1)) AS extension,
    COUNT(*) AS total_files
FROM document_metadata_score_report
WHERE TRY_CAST(summary_score AS DOUBLE) = 8
  AND document_name IS NOT NULL
GROUP BY lower(regexp_extract(document_name, '\\.([^.]+)$', 1))
ORDER BY total_files DESC;
